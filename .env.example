# SEC requires automated clients to identify the application and provide a contact email.
SEC_USER_AGENT="AI Infra Terminal timwong101@gmail.com"
DATABASE_URL="postgresql://ai_infra:ai_infra@localhost:5432/ai_infra"
# GitHub OAuth app credentials. Use /api/auth/github/callback as the callback path.
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
AUTH_BASE_URL="http://localhost:3000"
# Local development enables the seeded demo automatically. Production requires this opt-in.
ENABLE_DEMO_AUTH="false"
# Optional. Without this key, memo generation uses the evidence-grounded deterministic engine.
OPENAI_API_KEY=""
AI_MEMO_MODEL="gpt-5-mini"
AI_EMBEDDING_MODEL="text-embedding-3-small"
# Required by hosted schedulers calling POST /api/research-cycle.
SCHEDULE_SECRET="replace-with-a-long-random-value"
