# SEC requires automated clients to identify the application and provide a contact email.
SEC_USER_AGENT="AI Infra Terminal timwong101@gmail.com"
DATABASE_URL="postgresql://ai_infra:ai_infra@localhost:5432/ai_infra"
# Optional. Without this key, memo generation uses the evidence-grounded deterministic engine.
OPENAI_API_KEY=""
