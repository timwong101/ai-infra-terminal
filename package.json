{
  "name": "ai-infra-terminal",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "ingest:sec": "tsx --env-file-if-exists=.env.local scripts/ingest-sec.ts",
    "ingest:ir": "tsx --env-file-if-exists=.env.local scripts/ingest-ir.ts",
    "db:migrate": "tsx --env-file-if-exists=.env.local scripts/migrate-db.ts",
    "db:seed:e2e": "tsx --env-file-if-exists=.env.local scripts/seed-e2e.ts",
    "db:backfill": "tsx --env-file-if-exists=.env.local scripts/backfill-sec-details.ts",
    "db:backfill:ir": "tsx --env-file-if-exists=.env.local scripts/backfill-ir-details.ts",
    "db:process:ir": "tsx --env-file-if-exists=.env.local scripts/process-ir-queue.ts",
    "db:refresh": "tsx --env-file-if-exists=.env.local scripts/backfill-sec-details.ts --force",
    "db:alerts": "tsx --env-file-if-exists=.env.local scripts/generate-alerts.ts",
    "research:cycle": "tsx --env-file-if-exists=.env.local scripts/run-research-cycle.ts",
    "research:briefing": "tsx --env-file-if-exists=.env.local scripts/generate-research-briefing.ts",
    "research:embeddings": "tsx --env-file-if-exists=.env.local scripts/backfill-research-embeddings.ts",
    "research:intelligence": "tsx --env-file-if-exists=.env.local scripts/sync-company-intelligence.ts",
    "db:generate": "drizzle-kit generate",
    "db:setup": "pnpm db:migrate && pnpm db:backfill && pnpm db:backfill:ir",
    "test": "pnpm run build && node --test tests/rendered-html.test.mjs && tsx --test tests/sec-normalize.test.ts tests/sec-ingest.test.ts tests/sec-extract.test.ts tests/sec-event-policy.test.ts tests/ir-normalize.test.ts tests/ir-extract.test.ts tests/filing-compare.test.ts tests/alert-classification.test.ts tests/evidence-quality.test.ts tests/research-evidence.test.ts tests/research-briefing.test.ts tests/memo-verification.test.ts tests/research-assistant-verification.test.ts tests/company-intelligence.test.ts tests/company-coverage.test.ts",
    "test:e2e": "playwright test",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.11",
    "@ai-sdk/react": "4.0.24",
    "ai": "^7.0.23",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "pg": "^8.22.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "streamdown": "2.5.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
